// Prisma schema do RayLabs e-commerce.
// Gera client em node_modules/@prisma/client (default).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  PAYMENT_FAILED
}

enum OutboxEventStatus {
  PENDING
  PUBLISHED
  FAILED
}

model Customer {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  document     String   @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  deletedAt    DateTime?
  orders       Order[]

  @@index([deletedAt])
  @@map("customers")
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  // Preço em centavos para evitar erros de ponto flutuante.
  priceCents BigInt
  stock     Int
  // Versão para optimistic lock (não usado por padrão, deixamos como invariante adicional).
  version   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  items     OrderItem[]

  @@index([deletedAt])
  @@map("products")
}

model Order {
  id         String       @id @default(uuid()) @db.Uuid
  customerId String       @db.Uuid
  customer   Customer     @relation(fields: [customerId], references: [id])
  status     OrderStatus  @default(PENDING_PAYMENT)
  totalCents BigInt
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?
  items      OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([deletedAt])
  @@map("orders")
}

model OrderItem {
  id             String  @id @default(uuid()) @db.Uuid
  orderId        String  @db.Uuid
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String  @db.Uuid
  product        Product @relation(fields: [productId], references: [id])
  productName    String
  unitPriceCents BigInt
  quantity       Int

  @@index([orderId])
  @@map("order_items")
}

model OutboxEvent {
  id          String            @id @default(uuid()) @db.Uuid
  aggregateId String            @db.Uuid
  type        String
  payload     Json
  status      OutboxEventStatus @default(PENDING)
  attempts    Int               @default(0)
  lastError   String?
  createdAt   DateTime          @default(now())
  publishedAt DateTime?

  @@index([status, createdAt])
  @@map("outbox_events")
}

model ProcessedEvent {
  messageId   String   @id
  consumer    String
  processedAt DateTime @default(now())

  @@index([consumer])
  @@map("processed_events")
}
