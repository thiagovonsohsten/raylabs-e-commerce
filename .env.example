# Postgres
POSTGRES_USER=raylabs
POSTGRES_PASSWORD=raylabs
POSTGRES_DB=raylabs
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_USER=raylabs
RABBITMQ_PASSWORD=raylabs
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Backend
API_PORT=3000
DATABASE_URL=postgresql://raylabs:raylabs@postgres:5432/raylabs?schema=public
RABBITMQ_URL=amqp://raylabs:raylabs@rabbitmq:5672
JWT_SECRET=super-secret-change-me
JWT_EXPIRES_IN=1d
LOG_LEVEL=info

# Payment simulation
PAYMENT_SUCCESS_RATE=0.9
PAYMENT_PROCESSING_MS=500

# Retry / DLQ
MAX_DELIVERY_ATTEMPTS=4
RETRY_BASE_DELAY_MS=1000

# Outbox relay
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=20

# Frontend
VITE_API_URL=http://localhost:3000
FRONTEND_PORT=5173
